---
export interface Props {
  title: string;
  date: Date;
  tag: string;
  slug: string;
}
const { title, date, tag, slug } = Astro.props;
const day = date.toLocaleDateString('en-GB', { day: '2-digit' });
const month = date.toLocaleDateString('en-GB', { month: 'short' });
const tagClass = {
  'Event recap':    'tag-event',
  'News':           'tag-news',
  'Growing season': 'tag-grow',
  'Community':      'tag-community',
};
---
<article class="update-card">
  <div class="update-date" aria-label={date.toLocaleDateString('en-GB')}>
    <strong>{day}</strong>
    <small>{month}</small>
  </div>
  <div class="update-body">
    <span class={`tag ${tagClass[tag] ?? 'tag-news'}`}>{tag}</span>
    <h3>{title}</h3>
    <slot />
  </div>
</article>

<style>
  .update-card {
    display: flex;
    gap: 1.25rem;
    background: var(--color-bg-alt);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.25rem;
  }
  .update-date { min-width: 44px; text-align: center; flex-shrink: 0; }
  .update-date strong {
    display: block;
    /*
     * 24px has no exact token (--size-xl is ~22px, --size-2xl is ~28px).
     * Using --size-2xl (1.75rem) as the closest larger option for the date numeral.
     */
    font-size: var(--size-2xl);
    font-weight: var(--weight-bold);
    color: var(--color-green-dark);
    line-height: 1;
  }
  .update-date small {
    font-size: var(--size-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .update-body h3 {
    font-size: var(--size-base);
    font-weight: var(--weight-medium);
    color: var(--color-text);
    margin: 4px 0 6px;
  }
  .update-body :global(p) {
    font-size: var(--size-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-body);
    max-width: none;
  }
  .tag {
    display: inline-block;
    font-size: var(--size-xs);
    font-weight: var(--weight-bold);
    padding: 3px 9px;
    border-radius: var(--radius-sm);
    margin-bottom: 4px;
  }
  .tag-event    { background: var(--color-tag-event-bg);     color: var(--color-tag-event-text); }
  .tag-news     { background: var(--color-tag-news-bg);      color: var(--color-tag-news-text); }
  .tag-grow     { background: var(--color-tag-grow-bg);      color: var(--color-tag-grow-text); }
  .tag-community{ background: var(--color-tag-community-bg); color: var(--color-tag-community-text); }
</style>
