---
---
<header class="nav-wrap">
  <nav class="nav">
    <a href="/#home" class="nav-logo" aria-label="Health Means Wealth home">
      <img src="/logos/hmw-logo-horizontal-white.svg" alt="Health Means Wealth" height="38" decoding="async" />
    </a>
    <button class="nav-burger" aria-label="Open menu" aria-expanded="false" id="burger">
      <span></span><span></span><span></span>
    </button>
    <ul class="nav-links" id="nav-links" role="list">
      <li><a href="/#about">About</a></li>
      <li><a href="/#gallery">Gallery</a></li>
      <li><a href="/#events">Events</a></li>
      <li><a href="/#updates">Updates</a></li>
      <li><a href="/#find-us">Find Us</a></li>
      <li><a href="/#contact">Contact</a></li>
    </ul>
  </nav>
</header>

<style>
  .nav-wrap {
    background: var(--color-green-dark);
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 1px 0 rgba(0,0,0,0.15);
  }
  .nav {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-3);
    height: var(--nav-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
  }
  .nav-logo img { height: 38px; width: auto; }

  /* Mobile base — burger visible, links hidden as dropdown */
  .nav-burger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }
  .nav-burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-bg-alt);
    border-radius: 2px;
  }
  .nav-links {
    display: none;
    flex-direction: column;
    list-style: none;
    position: absolute;
    top: var(--nav-height);
    left: 0;
    right: 0;
    background: var(--color-green-dark);
    padding: var(--space-1) 0 var(--space-2);
    border-top: 1px solid rgba(255,255,255,0.1);
    gap: 0;
  }
  .nav-links.open { display: flex; }
  .nav-links a {
    color: var(--color-green-light);
    text-decoration: none;
    font-size: var(--size-base);
    padding: 14px var(--space-3);
    line-height: 1;
    display: block;
    /* transition defined in global.css */
  }

  /* Tablet and up — inline nav, no burger */
  @media (min-width: 640px) {
    .nav-burger { display: none; }
    .nav-links {
      display: flex;
      flex-direction: row;
      position: static;
      background: none;
      padding: 0;
      border-top: none;
    }
    .nav-links a {
      font-size: var(--size-sm);
      padding: 0 14px;
      line-height: var(--nav-height);
    }
  }
</style>

<script>
  const burger = document.getElementById('burger');
  const links = document.getElementById('nav-links');
  burger?.addEventListener('click', () => {
    const open = links?.classList.toggle('open');
    burger.setAttribute('aria-expanded', open ? 'true' : 'false');
  });
  links?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      links.classList.remove('open');
      burger?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
