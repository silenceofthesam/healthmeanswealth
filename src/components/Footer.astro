---
---
<footer class="footer">
  <div class="footer-inner">
    <div class="footer-logo">
      <img src="/logos/hmw-logo-stacked-white.svg" alt="Health Means Wealth" height="110" decoding="async" />
    </div>
    <div class="footer-links">
      <p>Heron Way Community Allotments, Feltham, London</p>
      <p><a href="mailto:hello@healthmeanswealth.org.uk">hello@healthmeanswealth.org.uk</a></p>
      <p class="footer-small">
        <a href="/privacy">Privacy policy</a> ·
        <a href="/accessibility">Accessibility statement</a>
      </p>
      <p class="footer-small">© {new Date().getFullYear()} Health Means Wealth. Community group — on the path to registered charity status.</p>
    </div>
    <div class="footer-social">
      <a href="https://www.facebook.com/p/Health-means-Wealth-100083095098532/" target="_blank" rel="noopener" class="social-btn">Facebook</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-green-dark);
    padding: var(--space-6) var(--space-3);
  }

  /* Mobile base: single column, centred */
  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    align-items: start;
    text-align: center;
  }
  .footer-logo {
    display: flex;
    justify-content: center;
  }
  .footer-social {
    display: flex;
    flex-direction: row;
    justify-content: center;
    gap: 8px;
  }

  /* Tablet+: three-column layout */
  @media (min-width: 640px) {
    .footer-inner {
      grid-template-columns: auto 1fr auto;
      gap: 2.5rem;
      text-align: left;
    }
    .footer-logo { display: block; }
    .footer-social { flex-direction: column; justify-content: flex-start; }
  }

  .footer-logo img { height: 110px; width: auto; opacity: 0.92; }
  .footer-links p {
    color: rgba(255,255,255,0.65);
    font-size: var(--size-sm);
    margin-bottom: 6px;
    max-width: none;
  }
  .footer-links a { color: var(--color-green-light); text-decoration: none; }
  .footer-links a:hover { text-decoration: underline; }
  .footer-small {
    font-size: var(--size-xs) !important;
    color: rgba(255,255,255,0.38) !important;
    margin-top: var(--space-2) !important;
  }
  .social-btn {
    background: rgba(255,255,255,0.08);
    color: var(--color-green-light);
    text-decoration: none;
    font-size: var(--size-sm);
    padding: 8px 16px;
    border-radius: var(--radius-sm);
    text-align: center;
    transition: background var(--transition-fast);
  }
  .social-btn:hover { background: rgba(255,255,255,0.15); }
</style>
