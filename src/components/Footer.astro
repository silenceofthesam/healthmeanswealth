---
---
<footer class="footer">
  <div class="footer-inner">
    <div class="footer-logo">
      <img src="/logos/hmw-logo-stacked-white.svg" alt="Health Means Wealth" height="110" width="auto" />
    </div>
    <div class="footer-links">
      <p>Heron Way Community Allotments, Feltham, London</p>
      <p><a href="mailto:hello@healthmeanswealth.org.uk">hello@healthmeanswealth.org.uk</a></p>
      <p class="footer-small">
        <a href="/privacy">Privacy policy</a> ·
        <a href="/accessibility">Accessibility statement</a>
      </p>
      <p class="footer-small">© {new Date().getFullYear()} Health Means Wealth. Community group — on the path to registered charity status.</p>
    </div>
    <div class="footer-social">
      <a href="https://www.facebook.com/p/Health-means-Wealth-100083095098532/" target="_blank" rel="noopener" class="social-btn">Facebook</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--soil);
    padding: 3rem 1.5rem;
  }
  .footer-inner {
    max-width: 960px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 2.5rem;
    align-items: start;
  }
  .footer-logo img { height: 110px; width: auto; opacity: 0.92; }
  .footer-links p { color: rgba(255,255,255,0.65); font-size: 14px; margin-bottom: 6px; }
  .footer-links a { color: var(--sprout); text-decoration: none; }
  .footer-links a:hover { text-decoration: underline; }
  .footer-small { font-size: 12px !important; color: rgba(255,255,255,0.38) !important; margin-top: 1rem !important; }
  .footer-social { display: flex; flex-direction: column; gap: 8px; }
  .social-btn {
    background: rgba(255,255,255,0.08);
    color: var(--sprout);
    text-decoration: none;
    font-size: 13px;
    padding: 8px 16px;
    border-radius: 6px;
    text-align: center;
    transition: background 0.15s;
  }
  .social-btn:hover { background: rgba(255,255,255,0.15); }
  @media (max-width: 680px) {
    .footer-inner { grid-template-columns: 1fr; text-align: center; }
    .footer-logo { display: flex; justify-content: center; }
    .footer-social { flex-direction: row; justify-content: center; }
  }
</style>
