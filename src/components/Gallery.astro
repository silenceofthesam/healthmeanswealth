---
import { readdir } from 'node:fs/promises';
import { join } from 'node:path';

let images = [];
try {
  const files = await readdir(join(process.cwd(), 'public/images/gallery'));
  images = files
    .filter(f => /\.(jpe?g|png|webp|avif)$/i.test(f))
    .map(f => `/images/gallery/${f}`);
} catch {
  images = [];
}

/*
 * Placeholder colours are defined as CSS classes (ph-1 … ph-6) in the <style>
 * block below, referencing CSS custom properties — no inline styles.
 */
const placeholders = [
  { label: 'Summer BBQ',             cls: 'ph-1' },
  { label: 'Planting day',           cls: 'ph-2' },
  { label: 'Harvest time',           cls: 'ph-3' },
  { label: 'Coronation celebration', cls: 'ph-4' },
  { label: 'Coffee morning',         cls: 'ph-5' },
  { label: 'Volunteer day',          cls: 'ph-6' },
];
const showPlaceholders = images.length === 0;
---

<div class="gallery-grid">
  {showPlaceholders
    ? placeholders.map((p, i) => (
        <div
          class={`gallery-item img-wrap ${p.cls}${i === 0 ? ' large' : ''}`}
          aria-label={`Placeholder: ${p.label}`}>
          <span class="gallery-label">{p.label}</span>
        </div>
      ))
    : images.map((src, i) => (
        <div class={`gallery-item img-wrap${i === 0 ? ' large' : ''}`}>
          <img
            src={src}
            alt={`Health Means Wealth — photo ${i + 1}`}
            loading="lazy"
            decoding="async"
          />
        </div>
      ))
  }
</div>

<style>
  /* TASK 7 — mobile-first: 2 cols → 3 → 4 */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-2);
  }

  @media (min-width: 640px) {
    .gallery-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .gallery-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* TASK 5 — .img-wrap applied via global.css; local overrides for gallery */
  .gallery-item {
    aspect-ratio: 4 / 3;
    position: relative;
    /* border-radius and overflow come from .img-wrap in global.css */
  }
  .gallery-item.large {
    grid-column: span 2;
    grid-row: span 2;
    aspect-ratio: auto;
    min-height: 280px;
  }

  /* Gallery label */
  .gallery-label {
    position: absolute;
    bottom: 10px;
    left: 12px;
    color: rgba(255,255,255,0.85);
    font-size: var(--size-xs);
    font-weight: var(--weight-bold);
  }

  /* Placeholder background classes — colours reference tokens from global.css */
  .ph-1 { background: var(--color-green-dark); }
  .ph-2 { background: var(--color-placeholder-2); }
  .ph-3 { background: var(--color-placeholder-3); }
  .ph-4 { background: var(--color-placeholder-4); }
  .ph-5 { background: var(--color-green-mid); }
  .ph-6 { background: var(--color-green-light); }
</style>
