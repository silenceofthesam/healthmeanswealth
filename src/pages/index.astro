---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import UpdateCard from '../components/UpdateCard.astro';
import EventCard from '../components/EventCard.astro';
import Gallery from '../components/Gallery.astro';
import { getCollection, render } from 'astro:content';

const allUpdates = await getCollection('updates');
const updates = allUpdates
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);

const allEvents = await getCollection('events');
const events = allEvents.sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());
---

<Base>
  <Nav />

  <div class="hero-wrap" id="home">
    <div class="hero">
      <div class="hero-badge">Community Allotment Group · Feltham, London</div>
      <h1>Growing food,<br><em>growing community</em></h1>
      <p class="hero-sub">Health Means Wealth is an inclusive allotment group at Heron Way in Feltham. We grow fresh fruit and vegetables, celebrate together, and show that urban spaces can be places of real nourishment — for body and spirit.</p>
      <div class="hero-btns">
        <a href="/#contact" class="btn-primary">Get involved</a>
        <a href="/#events" class="btn-secondary">Upcoming events</a>
      </div>
      <div class="hero-stats" aria-label="Key facts">
        <div class="hero-stat"><span class="stat-icon" aria-hidden="true">♿</span><small>Wheelchair accessible</small></div>
        <div class="hero-stat"><span class="stat-icon" aria-hidden="true">🌿</span><small>Fruit and veg growing</small></div>
        <div class="hero-stat"><span class="stat-icon" aria-hidden="true">🤝</span><small>All are welcome</small></div>
        <div class="hero-stat"><span class="stat-icon" aria-hidden="true">🏆</span><small>Award recognised</small></div>
      </div>
    </div>
  </div>

  <section id="about">
    <p class="section-label">What we do</p>
    <h2>A patch of green in the heart of Feltham</h2>
    <p class="section-intro">Founded with the belief that access to good food and good company is a right, not a privilege, Health Means Wealth brings together residents of all ages, backgrounds, and abilities. Our fully wheelchair-accessible allotment at Heron Way is a living example of what urban communities can achieve when they grow together.</p>
    <div class="pillars">
      <div class="pillar">
        <div class="pillar-icon pillar-icon--green" aria-hidden="true">🥕</div>
        <h3>Growing fruit and veg</h3>
        <p>Hands-on growing sessions for all skill levels. Learn to plant, tend, and harvest fresh produce from the ground up.</p>
      </div>
      <div class="pillar">
        <div class="pillar-icon pillar-icon--orange" aria-hidden="true">🎉</div>
        <h3>Community celebrations</h3>
        <p>From the King's Coronation to summer BBQs, we mark the seasons together with food, friendship, and festivities.</p>
      </div>
      <div class="pillar">
        <div class="pillar-icon pillar-icon--teal" aria-hidden="true">♿</div>
        <h3>Fully inclusive</h3>
        <p>Wheelchair accessible throughout. Our volunteers include borough members with autism and Asperger's — everyone has a valued role here.</p>
      </div>
      <div class="pillar">
        <div class="pillar-icon pillar-icon--blue" aria-hidden="true">🌍</div>
        <h3>Health and wellbeing</h3>
        <p>Fresh air, gentle physical activity, and genuine community connection — all proven to benefit mental and physical health.</p>
      </div>
    </div>
  </section>

  <div class="section--alt" id="gallery">
    <div class="alt-wrap">
      <p class="section-label">Gallery</p>
      <h2>Life at the allotment</h2>
      <p class="section-intro">A glimpse of what we get up to across the seasons — from planting days and harvest mornings to celebrations and community events.</p>
      <Gallery />
    </div>
  </div>

  <section class="section section--alt" id="events">
    <p class="section-label">Upcoming events</p>
    <h2>Come and join us</h2>
    <p class="section-intro">We hold regular sessions and seasonal celebrations throughout the year. All are welcome — no experience or prior involvement needed.</p>
    {events.length > 0 ? (
      <div class="events-list">
        {events.map(async (event) => {
          const { Content } = await render(event);
          return (
            <EventCard
              title={event.data.title}
              date={event.data.date}
              display_date={event.data.display_date}
              recurring={event.data.recurring}
              recurring_label={event.data.recurring_label}
            >
              <Content />
            </EventCard>
          );
        })}
      </div>
    ) : (
      <div class="events-empty">
        <p>No events scheduled right now — check back soon, or follow us on <a href="https://www.facebook.com/p/Health-means-Wealth-100083095098532/" target="_blank" rel="noopener">Facebook</a> for the latest.</p>
      </div>
    )}
  </section>

  <div id="updates">
    <div class="alt-wrap">
      <p class="section-label">Latest updates</p>
      <h2>From the allotment</h2>
      <p class="section-intro">News, event recaps, and seasonal notes from the team at Heron Way.</p>
      <div class="updates-list">
        {updates.map(async (update) => {
          const { Content } = await render(update);
          return (
            <UpdateCard
              title={update.data.title}
              date={update.data.date}
              tag={update.data.tag}
              slug={update.id}
            >
              <Content />
            </UpdateCard>
          );
        })}
      </div>
    </div>
  </div>

  <section class="section section--alt" id="recognition">
    <p class="section-label">Recognition</p>
    <h2>What people say</h2>
    <p class="section-intro">Health Means Wealth has been recognised by local councillors, the Mayor of Hounslow, and community professionals for its impact on residents' lives.</p>
    <div class="testimonials">
      <div class="testimonial">
        <blockquote>"Health Means Wealth has been a generous and uplifting partner to Autism Hounslow. They've opened up their beautiful sensory garden for our BBQs, gatherings, and quiet moments of rest - giving our community a space to breathe, connect and just be ourselves. Their support has made a real difference to our members and we're genuinely grateful for everything they've shared with us."</blockquote>
        <cite>— Roseann Connolly, Austism Hounslow</cite>
      </div>
      <div class="testimonial">
        <blockquote>"From the very first visit it was clear this group was something special — inclusive, warm, and producing real results for residents' health and wellbeing."</blockquote>
        <cite>— [Community Outreach Lead name], Hounslow</cite>
      </div>
      <div class="testimonial">
        <blockquote>"An outstanding community initiative that deserves recognition and support. The Mayor is proud to champion the work being done at Heron Way Allotments."</blockquote>
        <cite>— [Mayor name], Mayor of the London Borough of Hounslow</cite>
      </div>
    </div>
  </section>

  <section id="find-us">
    <p class="section-label">Find us</p>
    <h2>Come and visit</h2>
    <div class="find-us-grid">
      <div class="map-wrap">
        <iframe
          title="Heron Way Community Allotments on Google Maps"
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2485.6861359712007!2d-0.41486412393185496!3d51.4639188138796!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x487673052f7d4c87%3A0xbb816b7b663b5018!2sHeron%20Way%20Community%20Allotments!5e0!3m2!1sen!2suk!4v1775939707992!5m2!1sen!2suk"
          height="280"
          class="map-iframe"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>
        <p class="map-address">Heron Way Community Allotments, Feltham, London TW13</p>
      </div>
      <div class="contact-details">
        <div class="contact-row">
          <div class="contact-icon" aria-hidden="true">📧</div>
          <div>
            <h3>Email</h3>
            <a href="mailto:hello@healthmeanswealth.org.uk">hello@healthmeanswealth.org.uk</a>
          </div>
        </div>
        <div class="contact-row">
          <div class="contact-icon" aria-hidden="true">📅</div>
          <div>
            <h3>Regular sessions</h3>
            <p>Tuesdays 10am–12pm (coffee morning)<br />Plus seasonal events throughout the year</p>
          </div>
        </div>
        <div class="contact-row">
          <div class="contact-icon" aria-hidden="true">♿</div>
          <div>
            <h3>Accessibility</h3>
            <p>The allotment is fully wheelchair accessible. All abilities and ages are welcome.</p>
          </div>
        </div>
        <div class="contact-row">
          <div class="contact-icon" aria-hidden="true">🚌</div>
          <div>
            <h3>Getting here</h3>
            <p>Accessible by bus from Feltham town centre. Free street parking nearby.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="section--alt" id="contact">
    <div class="alt-wrap">
      <p class="section-label">Get in touch</p>
      <h2>Send us a message</h2>
      <p class="section-intro">Whether you want to volunteer, visit, ask a question, or find out about partnership or funding opportunities — we would love to hear from you.</p>
      <iframe data-tally-src="https://tally.so/embed/68O1Kk?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1" loading="lazy" width="100%" height="681" frameborder="0" marginheight="0" marginwidth="0" title="Health Means Wealth"></iframe>
      <script>var d=document,w="https://tally.so/widgets/embed.js",v=function(){"undefined"!=typeof Tally?Tally.loadEmbeds():d.querySelectorAll("iframe[data-tally-src]:not([src])").forEach((function(e){e.src=e.dataset.tallySrc}))};if("undefined"!=typeof Tally)v();else if(d.querySelector('script[src="'+w+'"]')==null){var s=d.createElement("script");s.src=w,s.onload=v,s.onerror=v,d.body.appendChild(s);}</script>
    </div>
  </div>

  <Footer />
</Base>

<style>
  /* ---- Hero ---- */
  .hero-wrap {
    background: linear-gradient(
      135deg,
      var(--color-green-dark) 0%,
      var(--color-green-deep) 60%,
      var(--color-green-mid) 100%
    );
    position: relative;
  }
  .hero {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 4.5rem var(--space-3) 3.5rem;
    text-align: center;
  }
  .hero-badge {
    display: inline-block;
    background: rgba(168,208,112,0.15);
    border: 1px solid rgba(168,208,112,0.35);
    color: var(--color-green-light);
    font-size: var(--size-xs);
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 5px 16px;
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-3);
  }
  /* Mobile base — heading starts at size-2xl; scaled up in breakpoints below */
  .hero h1 {
    color: var(--color-bg-alt);
    font-size: var(--size-2xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-3);
  }
  .hero h1 em { color: var(--color-green-light); font-style: normal; }
  .hero-sub {
    color: rgba(255,255,255,0.8);
    font-size: var(--size-lg);
    max-width: 580px;
    margin: 0 auto var(--space-4);
    line-height: var(--leading-body);
  }
  .hero-btns {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Button base styles — hover/transition defined in global.css */
  .btn-primary {
    background: var(--color-green-mid);
    color: var(--color-bg-alt);
    text-decoration: none;
    padding: 13px 26px;
    border-radius: var(--radius-sm);
    font-size: var(--size-sm);
    font-weight: var(--weight-bold);
  }
  .btn-secondary {
    background: transparent;
    color: var(--color-green-light);
    text-decoration: none;
    border: 1px solid rgba(168,208,112,0.45);
    padding: 13px 26px;
    border-radius: var(--radius-sm);
    font-size: var(--size-sm);
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-top: var(--space-6);
    padding-top: var(--space-4);
    border-top: 1px solid rgba(255,255,255,0.1);
    flex-wrap: wrap;
  }
  .hero-stat { text-align: center; }
  .stat-icon { display: block; font-size: var(--size-xl); margin-bottom: 6px; }
  .hero-stat small { color: rgba(255,255,255,0.6); font-size: var(--size-xs); }

  /* ---- Pillars — mobile first (1 → 2 → 3 columns) ---- */
  .pillars {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2);
  }
  .pillar {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    box-shadow: var(--shadow-sm);
    /* transition defined in global.css */
  }
  .pillar-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--color-green-pale);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--size-xl);
    margin-bottom: var(--space-3);
  }
  .pillar h3 {
    font-size: var(--size-base);
    font-weight: var(--weight-bold);
    color: var(--color-green-dark);
    margin-bottom: 6px;
  }
  .pillar p {
    font-size: var(--size-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-body);
    max-width: none;
  }

  /* ---- Event / Update lists ---- */
  .events-list  { display: flex; flex-direction: column; gap: 12px; }
  .updates-list { display: flex; flex-direction: column; gap: 14px; }

  /* ---- Testimonials — mobile first (1 → 2 → 3 columns) ---- */
  .testimonials {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2);
  }
  .testimonial {
    background: var(--color-bg-alt);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.4rem;
  }
  .testimonial blockquote {
    font-size: var(--size-sm);
    line-height: var(--leading-body);
    color: var(--color-text);
    font-style: italic;
    margin-bottom: 12px;
  }
  .testimonial cite {
    font-size: var(--size-xs);
    color: var(--color-text-muted);
    font-style: normal;
    font-weight: var(--weight-bold);
  }

  /* ---- Find us — mobile first (1 → 2 columns) ---- */
  .find-us-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    align-items: start;
  }
  /* iframe inline style replaced with class */
  .map-iframe {
    border: 0;
    border-radius: var(--radius-md);
    display: block;
    width: 100%;
  }
  .map-address {
    font-size: var(--size-sm);
    color: var(--color-text-muted);
    margin-top: 10px;
  }
  .contact-details { display: flex; flex-direction: column; gap: 1.25rem; }
  .contact-row { display: flex; gap: 14px; align-items: flex-start; }
  .contact-icon {
    width: 34px;
    height: 34px;
    background: var(--color-green-pale);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--size-base);
    flex-shrink: 0;
  }
  .contact-row h3 {
    font-size: var(--size-sm);
    font-weight: var(--weight-bold);
    color: var(--color-green-dark);
    margin-bottom: 2px;
  }
  .contact-row p,
  .contact-row a {
    font-size: var(--size-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    max-width: none;
  }
  .contact-row a:hover { text-decoration: underline; }

  /* ---- Responsive breakpoints (min-width, mobile first) ---- */
  @media (min-width: 640px) {
    .hero h1 { font-size: var(--size-3xl); }
    .hero-stats { gap: 2.5rem; }
    .pillars { grid-template-columns: repeat(2, 1fr); }
    .testimonials { grid-template-columns: repeat(2, 1fr); }
    .find-us-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (min-width: 1024px) {
    .hero h1 { font-size: var(--size-4xl); }
    .pillars { grid-template-columns: repeat(3, 1fr); }
    .testimonials { grid-template-columns: repeat(3, 1fr); }
  }
</style>
