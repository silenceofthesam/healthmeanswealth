---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Health Means Wealth — Heron Way Allotments, Feltham',
  description = 'Health Means Wealth is an inclusive community allotment group at Heron Way, Feltham. We grow fruit and vegetables, celebrate together, and welcome everyone.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/logos/hmw-icon-colour.svg" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="/logos/hmw-logo-stacked-colour.png" />
  <meta property="og:type" content="website" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --forest:  #2D5016;
      --leaf:    #7AB648;
      --sprout:  #A8D070;
      --cream:   #F9F7F3;
      --soil:    #1E3610;
      --text:    #1a1a1a;
      --muted:   #5a6a4a;
      --border:  rgba(0,0,0,0.08);
      --radius:  10px;
    }
    html { scroll-behavior: smooth; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      font-size: 16px;
      line-height: 1.7;
      color: var(--text);
      background: #fff;
    }
    img { max-width: 100%; display: block; }
    a { color: inherit; }
    .section-label {
      font-size: 11px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--leaf);
      font-weight: 600;
      margin-bottom: 0.35rem;
    }
    h2 {
      font-size: clamp(22px, 4vw, 30px);
      font-weight: 700;
      line-height: 1.25;
      margin-bottom: 0.75rem;
      color: var(--forest);
    }
    .section-intro {
      color: var(--muted);
      font-size: 16px;
      max-width: 580px;
      margin-bottom: 2rem;
      line-height: 1.75;
    }
    section { padding: 4rem 1.5rem; max-width: 960px; margin: 0 auto; }
    .alt-bg { background: var(--cream); }
    .alt-wrap { max-width: 960px; margin: 0 auto; padding: 4rem 1.5rem; }
  </style>
</head>
<body>
  <slot />
</body>
</html>
