---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Health Means Wealth — Heron Way Allotments, Feltham',
  description = 'Health Means Wealth is an inclusive community allotment group at Heron Way, Feltham. We grow fruit and vegetables, celebrate together, and welcome everyone.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/logos/hmw-icon-colour.svg" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="/logos/hmw-logo-stacked-colour.png" />
  <meta property="og:type" content="website" />
</head>
<body>
  <slot />
</body>
</html>
